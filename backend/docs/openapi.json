{
  "openapi": "3.0.3",
  "info": {
    "title": "Lovey Record Backend API",
    "version": "0.1.0",
    "description": "Machine-readable backend API surface for frontend integration and contract tests."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Healthy"
          }
        }
      }
    },
    "/api/commands/createModuleInstance": {
      "post": {
        "summary": "Create a module instance",
        "parameters": [
          {
            "name": "x-wx-openid",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Module instance created"
          },
          "401": {
            "description": "Authentication required"
          },
          "409": {
            "description": "Module instance conflict"
          }
        }
      }
    },
    "/api/commands/applySingleDayPeriodAction": {
      "post": {
        "summary": "Apply the resolved single-day period action",
        "parameters": [
          {
            "name": "x-wx-openid",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["moduleInstanceId", "selectedDate", "action"],
                "properties": {
                  "moduleInstanceId": {
                    "type": "string"
                  },
                  "selectedDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "action": {
                    "type": "string",
                    "enum": ["start", "revoke-start", "end-here", "noop"]
                  },
                  "confirmed": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Single-day period action applied or confirmation returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "moduleInstanceId": {
                      "type": "string"
                    },
                    "selectedDate": {
                      "type": "string",
                      "format": "date"
                    },
                    "appliedAction": {
                      "type": "string",
                      "nullable": true
                    },
                    "confirmationRequired": {
                      "type": "boolean"
                    },
                    "prompt": {
                      "type": "object",
                      "nullable": true
                    },
                    "effect": {
                      "type": "object",
                      "nullable": true
                    },
                    "effectPreview": {
                      "type": "object",
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/commands/recordPeriodDay": {
