        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["moduleInstanceId", "date"],
                  "properties": {
                    "moduleInstanceId": {
                      "type": "string"
                    },
                    "date": {
                      "type": "string",
                      "format": "date"
                    }
                  }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Period day recorded"
