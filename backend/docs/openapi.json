              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Access state returned"
          }
        }
      }
    },
    "/api/queries/getModuleSettings": {
      "get": {
        "summary": "Get module settings",
        "parameters": [
          {
            "name": "x-wx-openid",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "moduleInstanceId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Module settings returned"
          }
        }
      }
    }
  }
}
